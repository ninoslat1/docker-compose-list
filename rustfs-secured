version: "3.9"

services:
  rustfs:
    image: rustfs/rustfs:latest
    container_name: rustfs_container
    restart: unless-stopped

    ports:
      - "9000:9000"
      - "9001:9001"

    volumes:
      - /mnt/rustfs/data:/data

    environment:
      RUSTFS_ACCESS_KEY: YOUR_ADMIN_USERNAME
      RUSTFS_SECRET_KEY: YOUR_ADMIN_PASSWORD
      RUSTFS_CONSOLE_ENABLE: "true"
      RUSTFS_SERVER_DOMAINS: YOUR_SERVER_DOMAIN

    command:
      - --address
      - :9000
      - --console-enable
      - --server-domains
      - example.com
      - --access-key
      - rustfsadmin
      - --secret-key
      - rustfsadmin
      - /data
